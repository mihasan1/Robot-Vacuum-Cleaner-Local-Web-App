# Copy this file to `.env` and fill in your own values.
# How to get DEVICE_ID + LOCAL_KEY — see the README.

# Local device (find the robot's IP in your router's device / DHCP client list)
VACUUM_DEVICE_ID=your_device_id
VACUUM_DEVICE_IP=192.168.x.x
VACUUM_LOCAL_KEY=your_local_key
VACUUM_VERSION=3.5

# Tuya cloud (only needed for the floor map)
VACUUM_CLOUD_ORIGIN=https://openapi.tuyaeu.com
VACUUM_CLOUD_CLIENT=your_cloud_client_id
VACUUM_CLOUD_SECRET=your_cloud_secret

# Web server (0.0.0.0 to reach it from a phone / other PC on the LAN)
VACUUM_HOST=127.0.0.1
VACUUM_PORT=8765
